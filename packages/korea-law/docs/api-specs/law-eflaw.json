            { "name": "조문이동이전", "type": "int", "description": "조문이동이전" },
            { "name": "조문이동이후", "type": "int", "description": "조문이동이후" },
            { "name": "조문변경여부", "type": "string", "description": "Y값이 있으면 해당 조문내에 변경 내용 있음" },
            { "name": "조문내용", "type": "string", "description": "조문내용" },
            { "name": "조문참고자료", "type": "string", "description": "조문참고자료" }
          ],
          "children": {
            "항": {
