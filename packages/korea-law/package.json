{
  "name": "korea-law",
  "version": "1.1.3",
  "description": "Korea Law MCP Server - AI Legal Auditor for Korean Law Verification (한국 법률 MCP 서버)",
  "_syncNotes": {
    "warning": "⚠️ better-sqlite3, Node.js 버전 변경 시 law_ko, law_kr도 함께 업데이트 필요!",
    "related": [
      "law_ko/package.json",
      "law_kr/package.json",
      "services/korea-law-mcp/package.json"
    ],
    "docs": "docs/DEPENDENCY_SYNC_GUIDE.md"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@9.0.0",
  "bin": {
    "korea-law": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp src/db/schema.sql dist/db/ && cp src/db/schema-hybrid.sql dist/db/ && cp src/db/schema-krx.sql dist/db/",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "sync": "ts-node src/sync/daily-sync.ts",
    "sync:full": "ts-node src/sync/full-sync.ts",
    "sync:precedent": "ts-node src/sync/precedent-sync.ts",
    "sync:terms": "ts-node src/sync/term-extractor.ts",
    "sync:discover": "ts-node src/sync/discover-sync.ts",
    "sync:all": "pnpm sync && pnpm sync:precedent && pnpm sync:terms",
    "sync:complete": "pnpm sync:full && pnpm sync:precedent && pnpm sync:terms",
    "scheduler": "ts-node src/sync/scheduler.ts schedule",
    "scheduler:once": "ts-node src/sync/scheduler.ts once",
    "scheduler:test": "ts-node src/sync/__tests__/scheduler.test.ts",
    "scheduler:manual": "ts-node src/sync/__tests__/manual-sync.test.ts",
    "scheduler:verify": "ts-node src/sync/__tests__/verify-logs.test.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "embed:batch": "ts-node src/embedding/batch-embedding.ts",
    "embed:parallel": "ts-node src/embedding/parallel-embedding.ts",
    "embed:safe": "ts-node src/embedding/safe-embedding.ts",
    "embed:check": "ts-node src/embedding/check-progress.ts"
  },
  "keywords": [
    "law",
    "korea",
    "korean",
    "legal",
    "mcp",
    "model-context-protocol",
    "llm",
    "audit",
    "verification",
    "법률",
    "한국법",
    "법령",
    "국가법령정보센터"
  ],
  "author": "2seo <iyu974895@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/2seo/korea-law"
  },
  "dependencies": {
    "@markdown-media/core": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "@types/xml2js": "^0.4.14",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.5.0",
    "date-fns": "^3.0.0",
    "dotenv": "^16.3.0",
    "fast-xml-parser": "^4.3.0",
    "node-cron": "^3.0.3",
    "openai": "^4.104.0",
    "p-queue": "^9.0.1",
    "pdf2json": "^4.0.0",
    "pg": "^8.16.3",
    "uuid": "^11.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "jest": "^30.3.0",
    "playwright": "^1.57.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/**/*",
    "data/korea-law.db",
    "scripts/**/*"
  ]
}
