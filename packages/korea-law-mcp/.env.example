# MCP Server
MCP_PORT=3001
MCP_HOST=0.0.0.0

# Database (korea-law 패키지에서 사용)
KOREA_LAW_DB_PATH=./data/korea-law.db

# Korea Law API (데이터 동기화용)
KOREA_LAW_API_KEY=your-api-key

# Logging
LOG_LEVEL=info

# Hyperbrowser API (크롤링용)
# https://hyperbrowser.ai 에서 API 키 발급
HYPERBROWSER_API_KEY=your-hyperbrowser-api-key

# 크롤링 출력 디렉토리 (선택)
CRAWL_OUTPUT_DIR=./crawled_data
